# Reference .env for a Keywordista server deployment via docker-compose.yml.
# Copy this file to `.env` next to docker-compose.yml, fill in the values,
# then `docker compose up -d`.
#
# See docs/env-vars.md for the full env-var contract (§4.6.3 of the
# deploy plan). The vars below are the minimum to boot.

# ──────────────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────────────

# 64 hex chars (32 bytes). Generate ONCE per deployment and never lose
# it — this is the key that encrypts your App Store Connect .p8 and all
# other secrets at rest in the DB. Losing it means losing access to those
# secrets forever (the DB is still intact, just unreadable).
#
# Generate:
#   openssl rand -hex 32
KEYWORDISTA_ENCRYPTION_KEY=

# Public URL your team will access this deployment at. Used to render
# invite links. No trailing slash. Examples:
#   https://kw.studio.com
#   https://keywordista.your-domain.app
#   http://keywordista.local:8080   (local docker-only deploy)
KEYWORDISTA_PUBLIC_BASE_URL=

# ──────────────────────────────────────────────────────────────────────
# Optional: pre-baked admin (skip these to use the in-browser setup wizard)
# ──────────────────────────────────────────────────────────────────────

# KEYWORDISTA_ADMIN_EMAIL=you@studio.com

# bcrypt hash, NEVER plaintext. Generate locally:
#   htpasswd -nB -C 12 yourname | cut -d: -f2
# (Install: brew install httpd / apt install apache2-utils)
# KEYWORDISTA_ADMIN_PASSWORD_HASH=

# ──────────────────────────────────────────────────────────────────────
# Optional: Postgres instead of SQLite
# ──────────────────────────────────────────────────────────────────────

# Set this to flip to Postgres. Also uncomment the postgres service in
# docker-compose.yml. Format: postgres://USER:PASS@HOST:PORT/DB
# DATABASE_URL=postgres://keywordista:CHANGE_ME@postgres:5432/keywordista

# Password for the bundled docker-compose postgres service. Only matters
# if you uncommented that service.
# POSTGRES_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# Optional: Caddy reverse proxy with auto-TLS
# ──────────────────────────────────────────────────────────────────────

# Your domain (DNS A record must point here). Caddy fetches a
# Let's Encrypt cert automatically.
# CADDY_DOMAIN=

# ──────────────────────────────────────────────────────────────────────
# Optional: Litestream backup to S3-compatible object storage
# ──────────────────────────────────────────────────────────────────────

# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=

# ──────────────────────────────────────────────────────────────────────
# Optional: misc
# ──────────────────────────────────────────────────────────────────────

# Pin to an immutable digest instead of :latest (recommended for prod).
#   docker pull ghcr.io/bootuz/keywordista:latest
#   docker inspect ghcr.io/bootuz/keywordista:latest \
#     --format '{{ index .RepoDigests 0 }}'
# KEYWORDISTA_IMAGE=ghcr.io/bootuz/keywordista@sha256:abcd...

# trace | debug | info | notice | warning | error | critical
# KEYWORDISTA_LOG_LEVEL=info
