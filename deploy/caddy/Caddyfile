# Caddy reverse proxy for Keywordista with auto-TLS.
#
# Used by the optional `caddy` service in deploy/docker-compose.yml.
# Caddy fetches a Let's Encrypt cert for {$CADDY_DOMAIN} automatically
# on first request, renews it forever, and proxies all requests to
# the keywordista container on port 8080.
#
# DNS prerequisite: an A record for $CADDY_DOMAIN pointing to this
# host's public IP. Without it, Let's Encrypt's HTTP-01 challenge fails.

{$CADDY_DOMAIN} {
	# Proxy everything to the keywordista service on the docker network.
	# `keywordista` is the docker-compose service name; Docker's embedded
	# DNS resolves it to the container's IP.
	reverse_proxy keywordista:8080

	# Sensible security headers. The image's CSP / X-Frame-Options come
	# from the SPA's index.html and Vapor's middleware; these are
	# defense-in-depth at the proxy layer.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "strict-origin-when-cross-origin"
		# Caddy's auto-TLS sets Server: Caddy; hide it.
		-Server
	}

	encode zstd gzip
}
