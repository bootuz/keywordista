{
  "name": "keywordista-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Keywordista App Store keyword tracker — exposes read/write tools for apps, keywords, dashboards, and chart movements.",
  "type": "module",
  "bin": {
    "keywordista-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "manifest.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspector": "npx --yes @modelcontextprotocol/inspector node dist/index.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
